# Flask
SECRET_KEY=change-me-generate-with-python-c-import-secrets-print-secrets-token-hex-32
FLASK_ENV=development

# App
MACHINE_ID=9116
SERVER_PORT=8093

# Database (SQLite — relative path from app root)
DATABASE_PATH=data/database.db

# Pervasive ODBC DSN (configured in Windows ODBC Data Sources)
PERVASIVE_DSN=STAAMP_DB

# Set to true in development when Pervasive DB is unavailable
USE_MOCK_DB=false
