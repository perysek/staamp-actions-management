# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environment ───────────────────────────────────
.venv/
venv/
env/

# ── Environment / secrets ─────────────────────────────────
.env
.env.local
.env.*.local

# ── Runtime data (SQLite DB, uploads, generated PDFs) ─────
data/
*.db
*.sqlite
*.sqlite3

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── IDE / editor ──────────────────────────────────────────
.idea/
.vscode/
*.swp

# ── OS cruft ──────────────────────────────────────────────
Thumbs.db
desktop.ini
.DS_Store

# NOTE: static/css/output.css is intentionally NOT ignored.
# There is no Tailwind build pipeline on the deploy server,
# so the prebuilt output.css must be committed and shipped.
